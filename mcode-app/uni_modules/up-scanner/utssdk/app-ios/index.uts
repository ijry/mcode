import { ScanOptions, ScanFailResult } from '../interface.uts'
import { ScanCodeErrorCodeMap, UniErrorSubject } from '../unierror.uts'

/**
 * 临时最小实现：
 * 先保证 up-scanner 的 iOS 入口可编译，避免阻塞其他 UTS 插件产物生成。
 */
export function scanCode(options: ScanOptions) {
  const error: ScanFailResult = {
    errSubject: UniErrorSubject,
    errCode: 10003,
    errMsg: ScanCodeErrorCodeMap.get(10003) ?? 'iOS scanner is temporarily unavailable'
  }

  options.fail?.(error)
  options.complete?.(error)
}
