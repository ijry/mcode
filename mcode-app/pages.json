{
  "easycom": {
    "autoscan": true,
    "custom": {
      "^u-(.*)": "uview-plus/components/u-$1/u-$1.vue"
    }
  },
  "pages": [
    {
      "path": "pages/pair/index",
      "style": {
        "navigationBarTitleText": "Pair"
      }
    },
    {
      "path": "pages/targets/index",
      "style": {
        "navigationBarTitleText": "Targets"
      }
    },
    {
      "path": "pages/projects/index",
      "style": {
        "navigationBarTitleText": "Projects"
      }
    },
    {
      "path": "pages/sessions/index",
      "style": {
        "navigationBarTitleText": "Sessions"
      }
    },
    {
      "path": "pages/session-detail/index",
      "style": {
        "navigationBarTitleText": "Session"
      }
    },
    {
      "path": "pages/settings/index",
      "style": {
        "navigationBarTitleText": "Settings"
      }
    }
  ],
  "tabBar": {
    "color": "#666666",
    "selectedColor": "#111111",
    "borderStyle": "black",
    "list": [
      { "pagePath": "pages/targets/index", "text": "Targets" },
      { "pagePath": "pages/projects/index", "text": "Projects" },
      { "pagePath": "pages/sessions/index", "text": "Sessions" },
      { "pagePath": "pages/settings/index", "text": "Settings" }
    ]
  }
}
