{
  "easycom": {
    "autoscan": true,
    "custom": {
      "^u-(.*)": "uview-plus/components/u-$1/u-$1.vue",
      "^up-(.*)": "uview-plus/components/u-$1/u-$1.vue"
    }
  },
  "pages": [
    {
      "path": "pages/connections/index",
      "style": {
        "navigationBarTitleText": "MCode",
        "enablePullDownRefresh": false
      }
    },
    {
      "path": "pages/conversations/index",
      "style": {
        "navigationBarTitleText": "会话",
        "enablePullDownRefresh": true,
        "navigationStyle": "custom"
      }
    },
    {
      "path": "pages/conversation-detail/index",
      "style": {
        "navigationStyle": "custom",
        "navigationBarTitleText": "会话详情",
        "enablePullDownRefresh": false
      }
    },
    {
      "path": "pages/todos/index",
      "style": {
        "navigationStyle": "custom",
        "navigationBarTitleText": "待办",
        "enablePullDownRefresh": false
      }
    },
    {
      "path": "pages/circles/index",
      "style": {
        "navigationStyle": "custom",
        "navigationBarTitleText": "圈子",
        "enablePullDownRefresh": false
      }
    },
    {
      "path": "pages/profile/index",
      "style": {
        "navigationBarTitleText": "我的",
        "enablePullDownRefresh": false
      }
    },
    {
      "path": "pages/achievement/index",
      "style": {
        "navigationStyle": "custom",
        "navigationBarTitleText": "成就中心",
        "enablePullDownRefresh": false
      }
    },
    {
      "path": "pages/projects/index",
      "style": {
        "navigationBarTitleText": "项目列表",
        "enablePullDownRefresh": true
      }
    },
    {
      "path": "pages/sessions/index",
      "style": {
        "navigationBarTitleText": "项目会话",
        "enablePullDownRefresh": true
      }
    },
    {
      "path": "pages/project-git/index",
      "style": {
        "navigationBarTitleText": "Git 管理",
        "enablePullDownRefresh": true
      }
    },
    {
      "path": "pages/project-git-commit/index",
      "style": {
        "navigationBarTitleText": "提交详情",
        "enablePullDownRefresh": false
      }
    },
    {
      "path": "pages/project-git-diff/index",
      "style": {
        "navigationBarTitleText": "Diff",
        "enablePullDownRefresh": false
      }
    },
    {
      "path": "pages/auth/login",
      "style": {
        "navigationStyle": "custom",
        "navigationBarTitleText": "登录",
        "enablePullDownRefresh": false
      }
    },
    {
      "path": "pages/auth/register",
      "style": {
        "navigationStyle": "custom",
        "navigationBarTitleText": "注册",
        "enablePullDownRefresh": false
      }
    }
  ],
  "tabBar": {
    "color": "#8f8f94",
    "selectedColor": "#2979ff",
    "backgroundColor": "#ffffff",
    "borderStyle": "black",
    "list": [
      {
        "pagePath": "pages/connections/index",
        "text": "连接",
        "iconPath": "static/tabbar/connections.png",
        "selectedIconPath": "static/tabbar/connections-active.png"
      },
      {
        "pagePath": "pages/conversations/index",
        "text": "会话",
        "iconPath": "static/tabbar/conversations.png",
        "selectedIconPath": "static/tabbar/conversations-active.png"
      },
      {
        "pagePath": "pages/todos/index",
        "text": "待办",
        "iconPath": "static/tabbar/todos.png",
        "selectedIconPath": "static/tabbar/todos-active.png"
      },
      {
        "pagePath": "pages/circles/index",
        "text": "圈子",
        "iconPath": "static/tabbar/circles.png",
        "selectedIconPath": "static/tabbar/circles-active.png"
      },
      {
        "pagePath": "pages/profile/index",
        "text": "我的",
        "iconPath": "static/tabbar/profile.png",
        "selectedIconPath": "static/tabbar/profile-active.png"
      }
    ]
  },
  "globalStyle": {
    "navigationBarTextStyle": "black",
    "navigationBarTitleText": "MCode",
    "navigationBarBackgroundColor": "#ffffff",
    "backgroundColor": "#f8f8f8"
  }
}
